# Frontend — leave unset in local dev to use the Vite proxy (avoids CORS).
# Set to the full backend URL for production builds.
# VITE_API_BASE_URL=http://localhost:8000VITE_GOOGLE_MAPS_API_KEY=

# Backend
KOSTREET_ENV=development
KOSTREET_API_V1_PREFIX=/api/v1
KOSTREET_CORS_ORIGINS=http://localhost:5173,http://localhost:5174
KOSTREET_DATABASE_URL=sqlite:///./kostreet.db
KOSTREET_UPLOAD_DIR=backend/uploads
KOSTREET_ADMIN_SECRET=change-me-to-a-long-random-secret

# Optional imagery integrations
GOOGLE_MAPS_API_KEY=
KOSTREET_AUDIT_ON_DEMAND_MAX_PER_RUN_PER_HOUR=10
MAPBOX_ACCESS_TOKEN=
